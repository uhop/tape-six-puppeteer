{
  "name": "tape-six-puppeteer",
  "version": "1.1.0",
  "description": "Puppeteer-based browser test runner for tape-six. Runs each test file in its own iframe inside headless Chrome. Works with Node, Deno, and Bun.",
  "type": "module",
  "bin": {
    "tape6-puppeteer": "bin/tape6-puppeteer.js",
    "tape6-puppeteer-node": "bin/tape6-puppeteer-node.js"
  },
  "scripts": {
    "lint": "prettier --check .",
    "lint:fix": "prettier --write .",
    "js-check": "tsc --project tsconfig.check.json",
    "browser": "puppeteer browsers install chrome",
    "browser:all": "puppeteer browsers install chrome && puppeteer browsers install firefox",
    "postinstall": "puppeteer browsers install chrome",
    "test": "node ./bin/tape6-puppeteer.js --start-server --flags FO",
    "test:firefox": "node ./bin/tape6-puppeteer.js --start-server --browser firefox --flags FO",
    "test:bun": "bun run ./bin/tape6-puppeteer.js --start-server --flags FO",
    "test:deno": "deno run -A ./bin/tape6-puppeteer.js --start-server --flags FO"
  },
  "keywords": [
    "tap",
    "tape6",
    "tape-six",
    "test",
    "test-runner",
    "unit-test",
    "testing",
    "harness",
    "browser",
    "puppeteer",
    "headless",
    "chrome",
    "chromium",
    "firefox",
    "iframe",
    "parallel",
    "cross-runtime",
    "nodejs",
    "deno",
    "bun",
    "esm",
    "es-modules"
  ],
  "author": "Eugene Lazutkin <eugene.lazutkin@gmail.com> (https://www.lazutkin.com)",
  "funding": "https://github.com/sponsors/uhop",
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uhop/tape-six-puppeteer.git"
  },
  "bugs": {
    "url": "https://github.com/uhop/tape-six-puppeteer/issues"
  },
  "homepage": "https://github.com/uhop/tape-six-puppeteer#readme",
  "github": "http://github.com/uhop/tape-six-puppeteer",
  "llms": "https://raw.githubusercontent.com/uhop/tape-six-puppeteer/main/llms.txt",
  "llmsFull": "https://raw.githubusercontent.com/uhop/tape-six-puppeteer/main/llms-full.txt",
  "files": [
    "bin",
    "src",
    "llms.txt",
    "llms-full.txt"
  ],
  "dependencies": {
    "puppeteer": "^25.3.0",
    "tape-six": "^1.12.0"
  },
  "tape6": {
    "browser": [
      "/tests/test-*.html"
    ],
    "tests": [
      "/tests/test-*.*js"
    ],
    "importmap": {
      "imports": {
        "tape-six": "/node_modules/tape-six/index.js",
        "tape-six/": "/node_modules/tape-six/src/"
      }
    }
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3"
  },
  "allowScripts": {
    "puppeteer@25.3.0": true
  }
}
